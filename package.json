{
  "name": "vite-react-mobx-ssr",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "clean": "rm -rf ./dist",
    "serve": "vite --mode development --config vite.config.dev.ts",
    "build:prod": "vite build --mode production --config vite.config.prod.ts",
    "build:server": "vite build --mode production --config vite.config.server.ts",
    "build:node": "vite build --mode production --config vite.config.node.ts",
    "build:css": "esno creatAntdCss.ts",
    "build": "npm run clean & npm run build:prod && npm run build:server && npm run build:node && npm run build:css",
    "start": "node ./dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"**/*.{css,scss,sass}\" --fix",
    "lint:ts": "tsc -b --noEmit"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "antd": "^6.4.3",
    "axios": "^1.16.1",
    "express": "^5.2.1",
    "md5": "^2.3.0",
    "mobx": "^6.15.3",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "serialize-javascript": "^7.0.5",
    "store2": "^2.14.4"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.8.3",
    "@lincy/eslint-config": "^7.2.0",
    "@lincy/static-style-extract": "^1.0.5",
    "@lincy/stylelint-config": "^2.2.2",
    "@lincy/unocss-base-config": "^2.7.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/postcss-flexbugs-fixes": "^5.0.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/serialize-javascript": "^5.0.4",
    "@unocss/eslint-config": "^66.6.8",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "ahooks": "^3.9.7",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-mobx": "^0.0.14",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "esno": "^4.8.0",
    "jiti": "^2.7.0",
    "lru-cache": "^11.5.0",
    "postcss": "^8.5.15",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "^11.3.0",
    "sass": "^1.99.0",
    "stylelint": "^17.12.0",
    "typescript": "^6.0.3",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.13",
    "vite-plugin-mock": "^3.0.2"
  }
}
